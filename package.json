{
  "name": "usenib",
  "version": "0.1.0",
  "description": "Your design control plane — brand systems, design tokens, interactive prototypes, and AI-agent context from a single CLI",
  "type": "module",
  "bin": {
    "nib": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "bun src/cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "brand",
    "dtcg",
    "wcag",
    "tailwind",
    "ai",
    "mcp",
    "pencil",
    "prototype"
  ],
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^0.9.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "citty": "^0.1.6",
    "openai": "^4.80.0",
    "picocolors": "^1.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-tabs": "^0.8.0"
  }
}
